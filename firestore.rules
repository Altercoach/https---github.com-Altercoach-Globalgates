rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    function isOrderOwner(orderEmail) {
      return isSignedIn() && orderEmail != null && request.auth.token.email == orderEmail;
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isOrderOwner(resource.data.customer.email);
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
